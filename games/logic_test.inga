// INGA-LATRO game-logic tests. Run with:
//
//   inga test games/logic_test.inga
//
// Each zero-parameter `test*` function is one test. State lives in the
// `Game` service, so every test provides its own `freshGame` — the same
// way `main` provides the real one — and gets pristine tables.

use game { Game, freshGame }
use util { gn, gv }
use cards { chipsOf, rankName, suitName }
use poker { baseChips, baseMult, evalSelected, handTypeName }
use jokers { jokerPrice, sellPrice }
use state { blindName, selCount, sellJoker, sortKey, targetFor }

// Card id = rank * 4 + suit (rank 0 = "2" … 12 = Ace; suit 1 = hearts).
card :: (Int rank, Int suit) -> Int {
    rank * 4 + suit
}

pick :: (Int slot, Int c) uses Game {
    Game game
    game.hand().set(slot, c)
    game.sel().set(slot, 1)
}

emptyFrom :: (Int start) uses Game {
    Game game
    hand = game.hand()
    map(range(8), (i) -> {
        if i >= start {
            hand.set(i, -1)
        }
        0
    })
}

testCardBasics :: () {
    assertEq(rankName(12), "A")
    assertEq(rankName(0), "2")
    assertEq(suitName(1), "H")
    assertEq(chipsOf(card(12, 0)), 11) // aces are worth 11
    assertEq(chipsOf(card(3, 2)), 5) // "5" is worth 5
    assertEq(chipsOf(card(10, 1)), 10) // face cards are worth 10
}

testBlindsAndTargets :: () {
    assertEq(blindName(0), "Small Blind")
    assertEq(blindName(2), "Boss Blind")
    assertEq(targetFor(1, 0), 300)
    assertEq(targetFor(1, 2), 600)
    assert(targetFor(2, 0) > targetFor(1, 2))
}

testSelCount :: () {
    provide freshGame
    Game game
    assertEq(selCount(), 0)
    game.sel().set(0, 1)
    game.sel().set(4, 1)
    assertEq(selCount(), 2)
}

testSortKeyOrdersByRankThenSuit :: () {
    assert(sortKey(card(12, 0), false) > sortKey(card(11, 0), false))
    assert(sortKey(card(5, 1), true) > sortKey(card(9, 0), true) == (1 > 0))
    assertEq(sortKey(-1, false), -1) // empty slots sort last
}

testFlushBeatsNothing :: () {
    provide freshGame
    Game game
    // Five hearts with a rank gap: a flush (type 5), not a straight flush.
    pick(0, card(0, 1))
    pick(1, card(2, 1))
    pick(2, card(4, 1))
    pick(3, card(6, 1))
    pick(4, card(9, 1))
    emptyFrom(5)
    evalSelected()
    out = game.out()
    assertEq(gn(out, 0), 5)
    assertEq(handTypeName(gn(out, 0)), "Flush")
    assertEq(gn(out, 6), 5) // all five count as hearts for joker effects
}

testPairAndChips :: () {
    provide freshGame
    Game game
    pick(0, card(12, 0)) // A
    pick(1, card(12, 1)) // A
    pick(2, card(3, 2)) // 5
    emptyFrom(3)
    evalSelected()
    out = game.out()
    assertEq(handTypeName(gn(out, 0)), "Pair")
    assertEq(gn(out, 3), 11 + 11 + 5) // summed card chips
    assertEq(gn(out, 14), 1) // pair flag for Sly Joker
}

testStraightAndWheel :: () {
    provide freshGame
    Game game
    // A-2-3-4-5 "wheel" straight, mixed suits.
    pick(0, card(12, 0))
    pick(1, card(0, 1))
    pick(2, card(1, 2))
    pick(3, card(2, 3))
    pick(4, card(3, 0))
    emptyFrom(5)
    evalSelected()
    out = game.out()
    assertEq(handTypeName(gn(out, 0)), "Straight")
    assertEq(gn(out, 16), 1) // straight flag for Mystic Summit
}

testScoreScalesWithHandType :: () {
    assert(baseChips(8) > baseChips(1))
    assert(baseMult(8) > baseMult(1))
    assertEq(baseChips(1) * baseMult(1), 20) // a bare pair scores 10 x 2
}

testFreshGamesAreIndependent :: () {
    // Each provide constructs new instances — no state bleeds between runs.
    provide freshGame {
        Game game
        game.vals().set("money", 99)
    }
    provide freshGame
    assertEq(gv("money"), 0)
}

testSellJoker :: () {
    provide freshGame
    Game game
    jok = game.jok()
    // Own three jokers: ids 0, 11 (price 8), 5.
    jok.set(0, 0)
    jok.set(1, 11)
    jok.set(2, 5)
    game.vals().set("jokers", 3)
    game.vals().set("money", 0)

    sellJoker(1) // sell the middle one for half its price
    assertEq(gv("money"), sellPrice(11))
    assertEq(gv("jokers"), 2)
    assertEq(gn(jok, 0), 0)
    assertEq(gn(jok, 1), 5) // the tail shifted down

    sellJoker(7) // out of range: a no-op
    assertEq(gv("jokers"), 2)

    assert(sellPrice(0) >= 1) // cheapest joker still sells for something
    assert(sellPrice(14) == jokerPrice(14) / 2)
}
