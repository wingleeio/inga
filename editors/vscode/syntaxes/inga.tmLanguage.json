{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Inga",
  "scopeName": "source.inga",
  "patterns": [
    { "include": "#comments" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#function-calls" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.inga",
          "match": "//.*$"
        },
        {
          "name": "comment.block.inga",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "struct / enum declarations: `struct User = { Int id }`, `enum Shape = Circle | Dot`",
          "match": "\\b(struct|enum)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.inga" },
            "2": { "name": "entity.name.type.inga" }
          }
        },
        {
          "comment": "service declarations",
          "match": "\\b(service)\\s+([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.inga" },
            "2": { "name": "entity.name.type.interface.inga" }
          }
        },
        {
          "comment": "implementation declarations: `consoleLogger :: Logger {`",
          "match": "^\\s*([a-z][A-Za-z0-9_]*)\\s*(::)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.function.inga" },
            "2": { "name": "keyword.operator.signature.inga" },
            "3": { "name": "entity.name.type.interface.inga" }
          }
        },
        {
          "comment": "function / method declarations: `getUserById :: (id) {`",
          "match": "^\\s*([a-z][A-Za-z0-9_]*)\\s*(::)",
          "captures": {
            "1": { "name": "entity.name.function.inga" },
            "2": { "name": "keyword.operator.signature.inga" }
          }
        },
        {
          "comment": "builtin modules: `Gfx.rect(...)`, `Schedule.fixed(...)`",
          "match": "\\b(Gfx|Schedule)(?=\\.)",
          "captures": {
            "1": { "name": "entity.name.namespace.inga" }
          }
        },
        {
          "comment": "capability binding: `Cache cache`",
          "match": "^\\s*([A-Z][A-Za-z0-9_]*)\\s+([a-z][A-Za-z0-9_]*)\\s*$",
          "captures": {
            "1": { "name": "entity.name.type.interface.inga" },
            "2": { "name": "variable.other.readwrite.inga" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.inga",
          "match": "\\b(match|catch|fail|if|else)\\b"
        },
        {
          "name": "keyword.other.inga",
          "match": "\\b(struct|enum|service|provide|uses|lazy)\\b"
        },
        {
          "name": "constant.language.inga",
          "match": "\\b(true|false|None)\\b"
        },
        {
          "name": "support.function.constructor.inga",
          "match": "\\bSome\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.inga",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.inga",
          "match": "\\\\[ntr0\"\\\\$]"
        },
        {
          "name": "meta.embedded.interpolation.inga",
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.inga" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.inga" }
          },
          "patterns": [
            { "include": "#keywords" },
            { "include": "#numbers" },
            { "include": "#types" },
            { "include": "#operators" },
            { "include": "#function-calls" },
            { "include": "#identifiers" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "duration literals: 100.millis, 5.minutes",
          "match": "\\b(\\d[\\d_]*)\\.(millis|seconds|minutes|hours|days)\\b",
          "captures": {
            "1": { "name": "constant.numeric.integer.inga" },
            "2": { "name": "support.constant.duration.inga" }
          }
        },
        {
          "name": "constant.numeric.float.inga",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*\\b"
        },
        {
          "name": "constant.numeric.integer.inga",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.inga",
          "match": "\\b(Int|Float|Bool|String|Unit|Duration|Schedule)\\b"
        },
        {
          "name": "entity.name.type.inga",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.inga",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.signature.inga",
          "match": "::"
        },
        {
          "name": "keyword.operator.arrow.inga",
          "match": "->"
        },
        {
          "name": "keyword.operator.error-row.inga",
          "match": "(?<!=)!(?!=)"
        },
        {
          "name": "keyword.operator.comparison.inga",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.inga",
          "match": "(&&|\\|\\|)"
        },
        {
          "comment": "enum variant separator (after |> and || have been tried)",
          "name": "keyword.operator.enum-variant.inga",
          "match": "\\|"
        },
        {
          "name": "keyword.operator.arithmetic.inga",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.inga",
          "match": "="
        },
        {
          "name": "keyword.operator.option.inga",
          "match": "\\?"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "support.function.builtin.inga",
          "match": "\\b(println|print|show|encode|decode|map|getOrElse|orFail|retry|upTo|ignoreFailure|sleep|len|MutMap)(?=\\s*\\()"
        },
        {
          "match": "\\b([a-z][A-Za-z0-9_]*)(?=\\s*\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.inga" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.inga",
          "match": "\\b[a-z][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
